{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Pool health & capacity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "1 = pool is ONLINE. Anything else means degraded, faulted, offline, removed, suspended or unavailable.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 1, "text": "UNHEALTHY" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 0, "text": "ONLINE" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red" },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "id": 101,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "max by (hostname, zpool) (zfs_pool_health{hostname=~\"$hostname\", zpool=~\"$pool\", state=\"online\"})",
          "legendFormat": "{{hostname}} / {{zpool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool state",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Allocated vs pool size.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green" },
              { "color": "dark-yellow", "value": 70 },
              { "color": "dark-red", "value": 85 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "id": 102,
      "options": {
        "displayMode": "gradient",
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": false },
        "maxVizHeight": 300,
        "minVizHeight": 10,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "zfs_pool_allocated_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"} / zfs_pool_size_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"}",
          "legendFormat": "{{hostname}} / {{zpool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool used",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Free space fragmentation per pool. High fragmentation hurts write throughput on CoW filesystems.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "dark-yellow", "value": 40 },
              { "color": "dark-red", "value": 70 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "id": 103,
      "options": {
        "displayMode": "gradient",
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": false },
        "maxVizHeight": 300,
        "minVizHeight": 10,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "zfs_pool_fragmentation_ratio{hostname=~\"$hostname\", zpool=~\"$pool\"}",
          "legendFormat": "{{hostname}} / {{zpool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool fragmentation",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Capacity over time — watch for linear growth that eats into the quota headroom.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 104,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "zfs_pool_allocated_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"}",
          "legendFormat": "{{hostname}} / {{zpool}} used",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "zfs_pool_size_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"}",
          "legendFormat": "{{hostname}} / {{zpool}} size",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Pool capacity over time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Free space per pool.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 105,
      "options": {
        "legend": { "calcs": ["last", "min"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "zfs_pool_free_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"}",
          "legendFormat": "{{hostname}} / {{zpool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool free",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 200,
      "panels": [],
      "title": "ARC",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "ARC size vs configured max (zfs_arc_max kernel param).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*max.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 201,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "zfs_arc_size_bytes{hostname=~\"$hostname\"}",
          "legendFormat": "{{hostname}} size",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "zfs_arc_max_bytes{hostname=~\"$hostname\"}",
          "legendFormat": "{{hostname}} max",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "ARC size",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "ARC hit ratio = hits / (hits + misses). Sustained drops under load usually mean ARC is too small or working set is too large.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 202,
      "options": {
        "legend": { "calcs": ["last", "min"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "rate(zfs_arc_hits_total{hostname=~\"$hostname\"}[$__rate_interval]) / clamp_min(rate(zfs_arc_hits_total{hostname=~\"$hostname\"}[$__rate_interval]) + rate(zfs_arc_misses_total{hostname=~\"$hostname\"}[$__rate_interval]), 1)",
          "legendFormat": "{{hostname}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "ARC hit ratio",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 300,
      "panels": [],
      "title": "Datasets",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Used / (used + available) per dataset. Reaches 85% → warning alert fires, 95% → critical alert fires.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green" },
              { "color": "dark-yellow", "value": 70 },
              { "color": "dark-red", "value": 85 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 24 },
      "id": 301,
      "options": {
        "displayMode": "gradient",
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": false },
        "maxVizHeight": 300,
        "minVizHeight": 10,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(20, zfs_dataset_used_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"} / clamp_min(zfs_dataset_used_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"} + zfs_dataset_available_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"}, 1))",
          "legendFormat": "{{hostname}} {{name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Top 20 dataset fill ratio",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Top datasets by used bytes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue" }]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 24 },
      "id": 302,
      "options": {
        "displayMode": "gradient",
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": false },
        "maxVizHeight": 300,
        "minVizHeight": 10,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(20, zfs_dataset_used_bytes{hostname=~\"$hostname\", zpool=~\"$pool\"})",
          "legendFormat": "{{hostname}} {{name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Top 20 datasets by size",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 400,
      "panels": [],
      "title": "Backups (yoda ← chewie)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Age of the newest snapshot per backup dataset on yoda. Alert fires above 30h.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "dark-yellow", "value": 86400 },
              { "color": "dark-red", "value": 108000 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 37 },
      "id": 401,
      "options": {
        "displayMode": "gradient",
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": false },
        "maxVizHeight": 300,
        "minVizHeight": 10,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "time() - zfs_latest_snapshot_timestamp_seconds",
          "legendFormat": "{{dataset}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Snapshot age per backup dataset",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "description": "Systemd state for syncoid-* units on yoda. 1 = active, anything in `failed` means an alert will fire.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "text", "index": 0 }, "1": { "color": "green", "index": 1 } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text" }, { "color": "green", "value": 1 }]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [
              { "id": "mappings", "value": [
                { "options": { "0": { "color": "text", "index": 0 }, "1": { "color": "red", "index": 1, "text": "FAILED" } }, "type": "value" }
              ]}
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 37 },
      "id": 402,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "node_systemd_unit_state{name=~\"syncoid-.*\\\\.service\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Syncoid unit state",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["hostname", "name", "state", "Value"] } }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": { "hostname": 0, "name": 1, "state": 2, "Value": 3 },
            "renameByName": {}
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 41,
  "tags": ["storage", "zfs"],
  "templating": {
    "list": [
      {
        "current": {},
        "includeAll": false,
        "label": "Datasource",
        "name": "ds_prometheus",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
        "definition": "label_values(zfs_pool_health, hostname)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "Host",
        "name": "hostname",
        "options": [],
        "query": {
          "query": "label_values(zfs_pool_health, hostname)",
          "refId": "Prometheus-hostname-Variable-Query"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
        "definition": "label_values(zfs_pool_health{hostname=~\"$hostname\"}, zpool)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "Pool",
        "name": "pool",
        "options": [],
        "query": {
          "query": "label_values(zfs_pool_health{hostname=~\"$hostname\"}, zpool)",
          "refId": "Prometheus-pool-Variable-Query"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ZFS",
  "uid": "zfs-overview",
  "version": 1,
  "weekStart": ""
}
